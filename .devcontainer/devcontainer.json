{
  "name": "Node.js & TypeScript",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
  "mounts": [
    "source=pnpm-store-cache,target=/home/node/.local/share/pnpm/store,type=volume"
  ],
  "postCreateCommand": "bash ./.devcontainer/devcontainer.sh",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": false
    }
  }
}
