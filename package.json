{
  "name": "alice",
  "private": true,
  "scripts": {
    "test": "turbo run test",
    "dev": "turbo run dev",
    "format": "prettier --write --cache \"**/*.{ts,tsx,md,js,jsx,json,css}\"",
    "lint": "turbo run lint",
    "checktypes": "turbo run checktypes",
    "build": "turbo run build",
    "web": "pnpm --filter web",
    "api": "pnpm --filter api",
    "test:e2e": "start-server-and-test dev \"http://127.0.0.1:3000|http://127.0.0.1:5000\" \"pnpm --filter web cypress:run\"",
    "cypress:open": "pnpm --filter web cypress:open",
    "ui": "pnpm --filter ./packages/ui",
    "ui:add": "pnpm dlx shadcn@latest add -c ./packages/ui",
    "db": "pnpm --filter ./packages/db",
    "types": "pnpm --filter ./packages/types",
    "commit": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter web lint --"
    ],
    "apps/api/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter api lint --"
    ],
    "packages/ui/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @repo/ui lint --"
    ],
    "packages/db/**/*.{ts,tsx,js,jsx,mjs}": [
      "pnpm --filter @repo/db lint --"
    ],
    "packages/types/{eslint.config.mjs,src/index.ts}": [
      "pnpm --filter @repo/types lint --"
    ],
    "packages/types/src/generated/**/*.ts": []
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/cz-commitlint": "^21.2.0",
    "commitizen": "^4.3.2",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "start-server-and-test": "^3.0.11",
    "turbo": "^2.10.5",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
