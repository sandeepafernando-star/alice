{
  "name": "@repo/types",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./audit": {
      "types": "./src/audit.ts",
      "require": "./dist/audit.js",
      "default": "./dist/audit.js"
    },
    "./database": {
      "types": "./src/generated/supabase/database.types.ts",
      "require": "./dist/generated/supabase/database.types.js",
      "default": "./dist/generated/supabase/database.types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --max-warnings 0 --no-warn-ignored",
    "checktypes": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.19.43",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "typescript": "5.9.2"
  }
}
