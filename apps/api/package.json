{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "description": "a jira clone",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "vercel-build": "pnpm --filter @repo/types build",
    "start": "node dist/index.js",
    "lint": "eslint --max-warnings 0",
    "checktypes": "tsc --noEmit -p tsconfig.eslint.json"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.5",
    "detect-port": "^2.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "multer": "^2.2.0",
    "@novu/api": "^3.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.43",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.9"
  }
}
