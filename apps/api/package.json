{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "description": "a jira clone",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "express": "^4.22.2",
    "@clerk/express": "^2.1.31",
    "cors": "^2.8.5",
    "detect-port": "^2.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "typescript": "5.9.2",
    "@eslint/js": "^9.39.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.9"
  }
}
