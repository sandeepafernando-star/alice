# Required for all environments (local + Vercel Production/Preview)
NEXT_PUBLIC_API_URL="https://your-api.example.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional: auth email redirects (must be a full URL when set)
NEXT_PUBLIC_SITE_URL="https://your-web.example.com"

# Optional: Novu inbox (app runs without these)
NEXT_PUBLIC_NOVU_APP_ID="your-novu-app-id"
NEXT_PUBLIC_NOVU_SUBSCRIBER_ID="your-novu-subscriber-id"

# Optional: only needed for server-side admin Supabase operations
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
