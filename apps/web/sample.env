# Public variables only — safe for local .env.local and Vercel (client + server).

# Required
NEXT_PUBLIC_API_URL="https://your-api.example.com"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional — app builds and runs without these (warnings only if missing)
NEXT_PUBLIC_SITE_URL="https://your-web.example.com"
NEXT_PUBLIC_NOVU_APP_ID="your-novu-app-id"
NEXT_PUBLIC_NOVU_SUBSCRIBER_ID="your-novu-subscriber-id"

# Server-only secret — do NOT add to this file for production templates.
# Set SUPABASE_SERVICE_ROLE_KEY in Vercel → Environment Variables (never NEXT_PUBLIC_).
