{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web: Next.js (server)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web",
      "envFile": "${workspaceFolder}/apps/web/.env"
    },
    {
      "name": "Web: Next.js (client)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Web: Next.js (full stack)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web",
      "envFile": "${workspaceFolder}/apps/web/.env",
      "serverReadyAction": {
        "pattern": "(https?://localhost:3000)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "API: Express",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/apps/api/src/index.ts",
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/apps/api/.env",
      "runtimeArgs": ["--import", "tsx"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "API: attach",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}/apps/api",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "DB: seed",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/packages/db/src/seed.ts",
      "cwd": "${workspaceFolder}/packages/db",
      "envFile": "${workspaceFolder}/packages/db/.env",
      "runtimeArgs": ["--import", "tsx"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full stack: Web + API",
      "configurations": ["Web: Next.js (server)", "API: Express"],
      "stopAll": true
    }
  ]
}
