{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Monorepo: Attach",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["turbo", "run", "dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Vitest: Web",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/web",
      "program": "${workspaceFolder}/apps/web/node_modules/vitest/vitest.mjs",
      "args": ["run", "${file}"],
      "console": "integratedTerminal"
    },
    {
      "name": "Next.js: Web",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Express: API",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/api"
    }
  ],
  "compounds": [
    {
      "name": "Full stack: Web + API",
      "configurations": ["Next.js: Web", "Express: API"]
    }
  ]
}
